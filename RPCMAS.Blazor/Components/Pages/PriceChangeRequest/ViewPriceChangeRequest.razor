@page "/pricechangerequest/view/{Id:guid}"
@using RPCMAS.Core.Models
@rendermode InteractiveServer

<PageTitle>View Price Change Request</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-1">Price Change Request Details</h1>
            <div class="text-muted">Request header, line items, and audit status.</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/pricechangerequest/approval/history">Approval History</a>
            <a class="btn btn-outline-secondary" href="/pricechangerequest/approval">Approval Queue</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (isLoading)
    {
        <div>Loading request...</div>
    }
    else if (requestModel == null)
    {
        <div class="alert alert-warning">Request not found.</div>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-header">Request Information</div>
            <div class="card-body p-0">
                <table class="table table-sm table-bordered mb-0">
                    <tbody>
                        <tr>
                            <th style="width:220px;">Request Number</th>
                            <td>@requestModel.RequestNumber</td>
                        </tr>
                        <tr>
                            <th>Request Date</th>
                            <td>@requestModel.RequestDate.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                        <tr>
                            <th>Department</th>
                            <td>@requestModel.Department</td>
                        </tr>
                        <tr>
                            <th>Requested By</th>
                            <td>@requestModel.RequestedBy</td>
                        </tr>
                        <tr>
                            <th>Change Type</th>
                            <td>@GetChangeTypeLabel(requestModel.ChangeType)</td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>@requestModel.Status</td>
                        </tr>
                        <tr>
                            <th>Reason / Justification</th>
                            <td>@requestModel.ReasonOrJustification</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Items</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-bordered table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>SKU</th>
                                <th>Item Name</th>
                                <th>Current Price</th>
                                <th>Proposed New Price</th>
                                <th>Markdown %</th>
                                <th>Effective Date</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!requestModel.Details.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No items found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var detail in requestModel.Details)
                                {
                                    <tr>
                                        <td>@detail.SKU</td>
                                        <td>@detail.ItemName</td>
                                        <td>@detail.CurrentPrice.ToString("C")</td>
                                        <td>@detail.ProposedNewPrice.ToString("C")</td>
                                        <td>@detail.MarkdownPercentage.ToString("0.00")</td>
                                        <td>@detail.EffectiveDate.ToString("yyyy-MM-dd")</td>
                                        <td>@detail.Remarks</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            @if (requestModel.Status == RequestStatusEnum.Draft)
            {
                <a class="btn btn-primary" href="@($"/pricechangerequest/edit/{requestModel.Id}")">Edit Draft</a>
            }
        </div>
    }
</div>
