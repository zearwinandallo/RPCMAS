@page "/pricechangerequest/view/{Id:guid}"
@using RPCMAS.Core.Models
@rendermode InteractiveServer

<PageTitle>View Price Change Request</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-1">Price Change Request Details</h1>
            <div class="text-muted">Request header, line items, and audit status.</div>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" @onclick="GoBackAsync">Back</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (isLoading)
    {
        <div>Loading request...</div>
    }
    else if (requestModel == null)
    {
        <div class="alert alert-warning">Request not found.</div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-3 modern-table-card">
            <div class="card-header modern-table-header">Request Information</div>
            <div class="card-body p-0">
                <div class="table-responsive modern-table-wrap">
                    <table class="table table-sm mb-0 modern-info-table">
                    <tbody>
                        <tr>
                            <th style="width:220px;">Request Number</th>
                            <td>@requestModel.RequestNumber</td>
                        </tr>
                        <tr>
                            <th>Request Date</th>
                            <td>@requestModel.RequestDate.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                        <tr>
                            <th>Department</th>
                            <td>@requestModel.Department</td>
                        </tr>
                        <tr>
                            <th>Requested By</th>
                            <td>@requestModel.RequestedBy</td>
                        </tr>
                        <tr>
                            <th>Change Type</th>
                            <td>@GetChangeTypeLabel(requestModel.ChangeType)</td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>@requestModel.Status</td>
                        </tr>
                        <tr>
                            <th>Reason / Justification</th>
                            <td>@requestModel.ReasonOrJustification</td>
                        </tr>
                    </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-3 modern-table-card">
            <div class="card-header modern-table-header">Items</div>
            <div class="card-body p-0">
                <div class="table-responsive modern-table-wrap">
                    <table class="table table-sm mb-0 modern-data-table">
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>Item Name</th>
                                <th>Current Price</th>
                                <th>Proposed New Price</th>
                                <th>Markdown %</th>
                                <th>Effective Date</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!requestModel.Details.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No items found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var detail in requestModel.Details)
                                {
                                    <tr>
                                        <td>@detail.SKU</td>
                                        <td>@detail.ItemName</td>
                                        <td>@($"₱{detail.CurrentPrice:N2}")</td>
                                        <td>@($"₱{detail.ProposedNewPrice:N2}")</td>
                                        <td>@detail.MarkdownPercentage.ToString("0.00")</td>
                                        <td>@detail.EffectiveDate.ToString("yyyy-MM-dd")</td>
                                        <td>@detail.Remarks</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            @if (requestModel.Status == RequestStatusEnum.Draft)
            {
                <a class="btn btn-primary" href="@($"/pricechangerequest/edit/{requestModel.Id}")">Edit Draft</a>
            }
        </div>
    }
</div>

<style>
    .modern-table-card {
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
    }

    .modern-table-header {
        padding: 0.95rem 1.25rem;
        border-bottom: 1px solid #edf1f6;
        background: linear-gradient(180deg, #fbfcfe 0%, #f4f7fb 100%);
        color: #223042;
        font-weight: 700;
    }

    .modern-table-wrap {
        border-top: 0;
    }

    .modern-info-table,
    .modern-data-table {
        --bs-table-bg: transparent;
        margin: 0;
    }

    .modern-info-table th,
    .modern-info-table td,
    .modern-data-table th,
    .modern-data-table td {
        padding: 0.9rem 1rem;
        border-color: #edf1f6;
        vertical-align: middle;
    }

    .modern-info-table th {
        width: 220px;
        background: #f8fafc;
        color: #5b6777;
        font-weight: 600;
    }

    .modern-info-table td {
        color: #1f2b3a;
        font-weight: 500;
        background: #fff;
    }

    .modern-data-table thead th {
        background: #f8fafc;
        color: #5b6777;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        border-bottom-width: 1px;
    }

    .modern-data-table tbody tr {
        transition: background-color 0.2s ease;
    }

    .modern-data-table tbody tr:hover {
        background: #f8fbff;
    }

    .modern-data-table tbody td {
        color: #1f2b3a;
        font-weight: 500;
    }
</style>
