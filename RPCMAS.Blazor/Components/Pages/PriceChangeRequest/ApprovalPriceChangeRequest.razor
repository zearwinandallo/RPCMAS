@page "/pricechangerequest/approval"
@page "/pricechangerequest/approval/{ViewMode}"
@using RPCMAS.Core.Models
@rendermode InteractiveServer

<PageTitle>Price Change Request Approval</PageTitle>

<div class="container-fluid py-3">
    @if (!string.IsNullOrWhiteSpace(successNotificationMessage))
    {
        <div class="simple-success-toast shadow-sm">
            <span class="bi bi-check-circle-fill me-2" aria-hidden="true"></span>@successNotificationMessage
        </div>
    }

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h3 mb-1">@pageTitle</h1>
            <div class="text-muted">@pageSubtitle</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/pricechangerequest/approval">Approval Queue</a>
            <a class="btn btn-outline-secondary" href="/pricechangerequest/approval/history">Approved / History List</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="card mb-3">
        <div class="card-header">Filters</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Request Number</label>
                    <input class="form-control" @bind="filter.RequestNumber" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="selectedStatus">
                        <option value="">All</option>
                        @foreach (var status in requestStatuses)
                        {
                            if (status != RequestStatusEnum.Draft)
                            {
                                <option value="@status">@status</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Department</label>
                    <select class="form-select" value="@filter.Department" @onchange="HandleDepartmentChanged">
                        <option value="">All</option>
                        @foreach (var department in departments)
                        {
                            <option value="@GetDepartmentLabel(department)">@GetDepartmentLabel(department)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Change Type</label>
                    <select class="form-select" @bind="selectedChangeType">
                        <option value="">All</option>
                        @foreach (var changeType in changeTypes)
                        {
                            <option value="@changeType">@GetChangeTypeLabel(changeType)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Request Date</label>
                    <input class="form-control" type="date" value="@requestDateText" @onchange="HandleRequestDateChanged" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-secondary w-100" @onclick="LoadRequestsAsync">Search</button>
                </div>
            </div>
            <div class="mt-2">
                <button class="btn btn-link px-0" @onclick="ClearFiltersAsync">Clear Filters</button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 modern-approval-table-card">
        <div class="card-header d-flex justify-content-between align-items-center modern-approval-table-header">
            <span>@tableTitle</span>
            <span class="text-muted small">@requestHeaders.Count request(s)</span>
        </div>
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="p-3">Loading requests...</div>
            }
            else if (!requestHeaders.Any())
            {
                <div class="p-3">No requests found.</div>
            }
            else
            {
                <div class="table-responsive modern-approval-table-wrap">
                    <table class="table table-sm mb-0 align-middle modern-approval-table">
                        <thead>
                            <tr>
                                <th>Request Number</th>
                                <th>Request Date</th>
                                <th>Department</th>
                                <th>Requested By</th>
                                <th>Change Type</th>
                                <th>Status</th>
                                <th>Items</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in requestHeaders)
                            {
                                <tr>
                                    <td>@request.RequestNumber</td>
                                    <td>@request.RequestDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@request.Department</td>
                                    <td>@request.RequestedBy</td>
                                    <td>@GetChangeTypeLabel(request.ChangeType)</td>
                                    <td>@request.Status</td>
                                    <td>@request.Details.Count</td>
                                    <td class="text-nowrap">
                                        <a class="btn btn-sm btn-outline-secondary me-1 mb-1" href="@($"/pricechangerequest/view/{request.Id}")">View</a>
                                        @if (request.Status == RequestStatusEnum.Submitted)
                                        {
                                            <button class="btn btn-sm btn-success me-1 mb-1" disabled="@isActionRunning" @onclick="() => ApproveRequestAsync(request.Id)">Approve</button>
                                            <button class="btn btn-sm btn-danger mb-1" disabled="@isActionRunning" @onclick="() => RejectRequestAsync(request.Id)">Reject</button>
                                        }
                                        else if (request.Status == RequestStatusEnum.Approved)
                                        {
                                            <button class="btn btn-sm btn-primary mb-1" disabled="@isActionRunning" @onclick="() => ApplyRequestAsync(request.Id)">Apply</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .modern-approval-table-card {
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
    }

    .modern-approval-table-header {
        padding: 0.95rem 1.25rem;
        border-bottom: 1px solid #edf1f6;
        background: linear-gradient(180deg, #fbfcfe 0%, #f4f7fb 100%);
        color: #223042;
        font-weight: 700;
    }

    .modern-approval-table {
        --bs-table-bg: transparent;
    }

    .modern-approval-table thead th {
        padding: 0.9rem 1rem;
        border-color: #edf1f6;
        background: #f8fafc;
        color: #5b6777;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .modern-approval-table tbody td {
        padding: 0.95rem 1rem;
        border-color: #edf1f6;
        color: #1f2b3a;
        font-weight: 500;
    }

    .modern-approval-table tbody tr {
        transition: background-color 0.2s ease, transform 0.2s ease;
    }

    .modern-approval-table tbody tr:hover {
        background: #f8fbff;
    }

    .modern-approval-table tbody td.text-nowrap .btn {
        box-shadow: none;
    }

    .simple-success-toast {
        position: fixed;
        top: 1rem;
        right: 1rem;
        z-index: 1080;
        display: inline-flex;
        align-items: center;
        max-width: 360px;
        padding: 0.85rem 1rem;
        border: 1px solid #b9e7c9;
        border-radius: 14px;
        background: #ecfdf3;
        color: #166534;
        font-weight: 600;
    }
</style>
